# Docker Compose Configuration
# Copy this to .env for local overrides (ignored by git)
# Usage: cp .env.example .env

# Service Ports
# Change these if you have port conflicts with other running services
# The .env file is git-ignored, so your local overrides won't affect others
BACKEND_PORT=9095    # FastAPI backend (default: 9095)
FRONTEND_PORT=3000   # Frontend server (default: 3000)
DB_PORT=5432        # PostgreSQL database (default: 5432)

# Database Configuration
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
DB_URL=postgresql://app:app@db:5432/app

# AI Provider Configuration
# Supported providers: openai, anthropic, azure, mock
# Use 'mock' for development/testing without API keys
AI_PROVIDER=mock

# Provider API Keys (required for non-mock providers)
# AI_API_KEY=your-api-key-here

# Model Selection (optional, has sensible defaults)
# AI_MODEL=gpt-4o-mini              # For OpenAI
# AI_MODEL=claude-3-5-haiku-20241022  # For Anthropic
# AI_MODEL=gpt-4o-mini              # For Azure (deployment name)

# Azure-specific Configuration (required only for Azure provider)
# AI_AZURE_ENDPOINT=https://your-resource.openai.azure.com/
